# Toltec recipe for ink2tex. Format: https://github.com/toltec-dev/build/blob/main/docs/recipe-format.md
#
# Source is the published v0.1.0 tarball, pinned by sha256 — Toltec builds it in a clean
# `rust:v3.3` image. `make ipk` builds the same package from a local tree.

pkgnames=(ink2tex)
pkgdesc="Recognize handwritten math symbols and get the LaTeX command — on the tablet, offline"
url=https://github.com/Mx0FFFF/ink2tex
pkgver=0.1.0-1
timestamp=2026-07-12T00:00:00Z
section="math"
maintainer="Mx0FFFF <mx0ffffff@gmail.com>"
license=MIT
archs=(rm2)

image=rust:v3.3
source=(https://github.com/Mx0FFFF/ink2tex/archive/refs/tags/v0.1.0.zip)
sha256sums=(12306a9d7f7032e286609fd9be68eedd635f4b72352f807fa04b56dd0e834da1)

build() {
    # The device frontend is the only crate that touches the tablet; core is device-free.
    cargo build --release --target armv7-unknown-linux-gnueabihf -p ink2tex-rm
}

package() {
    install -D -m 755 "$srcdir"/target/armv7-unknown-linux-gnueabihf/release/ink2tex-rm \
        "$pkgdir"/opt/bin/ink2tex

    # The int8 weights + their label list. The binary looks here by default, so a user who
    # installs the package can just run `ink2tex --recognize` with no flags.
    install -D -m 644 "$srcdir"/train/model.iwt "$pkgdir"/opt/usr/share/ink2tex/model.iwt
    install -D -m 644 "$srcdir"/train/model.labels.txt \
        "$pkgdir"/opt/usr/share/ink2tex/model.labels.txt

    # Required, not decorative: the weights are trained on the Detexify database, which is
    # ODbL. A Produced Work must carry the attribution notice with it.
    install -D -m 644 "$srcdir"/ATTRIBUTION.md "$pkgdir"/opt/usr/share/ink2tex/ATTRIBUTION.md
}

configure() {
    echo ""
    echo "ink2tex installed. It is a command-line tool — run it over SSH:"
    echo ""
    echo "    ink2tex --recognize        # then draw ONE symbol on the tablet"
    echo ""
    echo "You get the five most likely LaTeX commands, ranked. ~16 ms per symbol, entirely"
    echo "on-device: no cloud, no network, no account."
    echo ""
    echo "Weights are trained on the Detexify dataset (ODbL) — see"
    echo "/opt/usr/share/ink2tex/ATTRIBUTION.md"
    echo ""
}
